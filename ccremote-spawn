#!/usr/bin/env bash
set -euo pipefail

# Spawn a fresh Claude Code session in tmux and connect it to Remote Control.
# Runs ON a Coder workspace (installed to ~/.local/bin/ccremote-spawn via
# dotfiles); the listener invokes it over `coder ssh`. Also runnable by hand.
#
#   ccremote-spawn "optional initial prompt"
#
# Prints the tmux session name on its last stdout line so the caller can
# reference it.
#
# Why tmux: the session must outlive this script (which returns immediately) so
# the phone has something to attach to; Remote Control attaches to that session.

PROMPT="${1:-}"
WORKDIR="${RC_WORKDIR:-$HOME}"                              # where claude starts
# Bypass permissions by default: a phone-driven session can't answer per-tool
# permission prompts, so they'd wedge it. Override with RC_CMD to change.
LAUNCH="${RC_CMD:-claude --dangerously-skip-permissions}"
BOOT_TIMEOUT="${RC_BOOT_TIMEOUT:-60}"                      # max 0.5s polls for the input box
SESSION="rc-$(date +%s)"

tmux new-session -d -s "$SESSION" -c "$WORKDIR" "$LAUNCH"

# Drive past claude's startup gates before sending anything that matters. A
# working dir claude hasn't seen shows a one-time "trust this folder?" prompt
# that otherwise swallows the keystrokes below (this was the bug: a blind sleep
# fired /remote-control straight into that dialog). Poll instead of sleeping, so
# we handle the trusted case, the untrusted case, and a slow boot uniformly.
# Accept trust at most once so a stray Enter can't land on the real prompt.
trusted=
ready=
for _ in $(seq 1 "$BOOT_TIMEOUT"); do
  pane="$(tmux capture-pane -p -t "$SESSION" 2>/dev/null || true)"
  if [ -z "$trusted" ] && printf '%s' "$pane" | grep -q "trust this folder"; then
    tmux send-keys -t "$SESSION" Enter        # selects "1. Yes, I trust this folder"
    trusted=1
  elif printf '%s' "$pane" | grep -Eq "bypass permissions on|\? for shortcuts|for agents"; then
    ready=1
    break
  fi
  sleep 0.5
done
[ -n "$ready" ] || echo "ccremote-spawn: input box not detected in time; sending keys anyway" >&2

# Connect Remote Control so the phone can attach. (RC_SKIP_RC=1 tests the
# plumbing without burning a real remote session.)
if [ "${RC_SKIP_RC:-0}" != "1" ]; then
  tmux send-keys -t "$SESSION" "/remote-control" Enter
  sleep 2
fi

# Kick off the first task, if one was supplied.
if [ -n "$PROMPT" ]; then
  tmux send-keys -t "$SESSION" "$PROMPT" Enter
fi

echo "$SESSION"
